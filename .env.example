# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Voyage AI (embeddings for style cloning; used by scripts/embed-tweets.ts) ---
VOYAGE_API_KEY=pa-...
# Optional: service-role key lets the data-pipeline scripts bypass RLS
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Session auth ---
# Any long random string. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# --- 3 hardcoded logins ---
USER1_USERNAME=marketing1
USER1_PASSWORD=change-me-1
USER1_DISPLAY_NAME=Marketing User 1

USER2_USERNAME=marketing2
USER2_PASSWORD=change-me-2
USER2_DISPLAY_NAME=Marketing User 2

USER3_USERNAME=marketing3
USER3_PASSWORD=change-me-3
USER3_DISPLAY_NAME=Marketing User 3

# --- Google Sheets logging (service account, no OAuth login flow) ---
# 1. Create a Google Cloud project -> enable "Google Sheets API"
# 2. Create a service account -> create a JSON key
# 3. Share the target Google Sheet with the service account's email (Editor access)
# 4. Fill in the values below from the JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service-account@my-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON key as-is (keep the \n escapes)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=the-id-from-the-sheet-url
# Optional, defaults to "Sheet1"
GOOGLE_SHEET_TAB=Sheet1

# --- Crawl4AI service (optional; link workspace falls back to a plain
# fetch + Open Graph parser when unset, so this can be left unconfigured) ---
# CRAWLER_SERVICE_URL=https://your-crawl4ai-service.example.com
# CRAWLER_SECRET=your-shared-secret
